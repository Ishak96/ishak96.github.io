{% if site.bib_search %}
  <script src="{{ '/assets/js/bibsearch.js' | relative_url | bust_file_cache }}" type="module"></script>
  <div class="pub-search-controls">
    <select id="bibsearch-type" class="bibsearch-type-select" aria-label="Search by field">
      <option value="all">All</option>
      <option value="title">Title</option>
      <option value="conference">Conference</option>
    </select>
    <input type="text" id="bibsearch" spellcheck="false" autocomplete="off" class="search bibsearch-form-input" placeholder="Search publications…">
    <button id="pub-sort-btn" class="btn btn-sm z-depth-0 pub-sort-btn" title="Sort by year" aria-label="Sort by year" data-order="desc">
      Year <i class="fa-solid fa-arrow-down-wide-short"></i>
    </button>
  </div>
{% endif %}
